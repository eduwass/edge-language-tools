{{--
@types {
  user: { name: string }
  posts: { title: string, body: string }[]
  activePage: string
}
--}}
@include('partials/nav')

<h1>
    Welcome back, {{ user.name }}
</h1>

@each(post in posts)
    <article>
        <h2>
            {{ post.title }}
        </h2>
        <p>
            {{ truncate(post.body, 120) }}
        </p>
    </article>
@else
    <p>
        No posts yet.
    </p>
@end

<footer>
    {{ pluralize('post', posts.length) }}
</footer>
