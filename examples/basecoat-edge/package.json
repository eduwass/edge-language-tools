{
  "name": "@edge-language-tools/basecoat-edge",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "edge-check templates && bun run check:attrs",
    "check:attrs": "bun run scripts/check-attrs.ts",
    "codegen": "edge-codegen templates --out edge-templates.d.ts",
    "gen-client": "edge-client build templates --out client --format js",
    "gen-docs": "bun run scripts/gen-docs.ts",
    "demo": "bun run src/server.ts",
    "docs:dev": "bun run gen-docs && blume dev --isolated",
    "docs:build": "bun run gen-docs && blume build --isolated"
  },
  "edge": {
    "check": {
      "requireTypes": [
        "templates/components/**"
      ]
    }
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.0",
    "edge-iconify": "^2.0.0",
    "edge.js": "^6.5.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@edge-language-tools/check": "workspace:*",
    "@edge-language-tools/client": "workspace:*",
    "@edge-language-tools/codegen": "workspace:*",
    "@edge-language-tools/core": "workspace:*",
    "@types/react": "^19.2.17",
    "blume": "^0.7.0",
    "typescript": "^5.8.0"
  }
}
