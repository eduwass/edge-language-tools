{{--
@name Label
@desc Form label element.
@types {
  // Associates the label with a control via the for attribute.
  htmlFor?: string
  // Additional HTML attributes forwarded to the root label element.
  [attr: string]: unknown
}
@url https://basecoatui.com/components/label/
@example
  @label({ htmlFor: 'preview-email' })
    Email address
  @end
--}}
<label {{
  html.attrs({
    class: 'label',
    ...(htmlFor ? { for: htmlFor } : {}),
  })
}}>
  {{{ await $slots.main() }}}
</label>
