{{--
@name Chart
@desc Chart canvas target; requires Chart.js and basecoat chart JS (chart.min.js).
@types {
  // Canvas element id passed to basecoat.chart().
  id: string
  // Accessible name via aria-label on the canvas.
  label?: string
  // Additional HTML attributes forwarded to the canvas element.
  [attr: string]: unknown
}
--}}
<canvas
  id="{{ id }}"
  {{
    html.attrs({
      ...(label ? { 'aria-label': label } : {}),
    })
  }}
></canvas>
