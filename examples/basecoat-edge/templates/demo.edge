<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>basecoat-edge demo</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/basecoat-css@1.0.2/dist/basecoat.cdn.min.css" />
  <script src="https://cdn.jsdelivr.net/npm/basecoat-css@1.0.2/dist/js/all.min.js" defer></script>
  <style>
    body { font-family: system-ui, sans-serif; margin: 0; padding: 2rem; background: var(--background, #fff); color: var(--foreground, #111); }
    .demo-grid { display: grid; gap: 2rem; max-width: 72rem; margin: 0 auto; }
    .demo-section h2 { margin: 0 0 1rem; font-size: 1.125rem; }
    .demo-row { display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: center; }
  </style>
</head>
<body>
  <div class="demo-grid">
    <header>
      <h1>basecoat-edge</h1>
      <p>Typed EdgeJS components wrapping <a href="https://basecoatui.com">basecoat UI</a>.</p>
    </header>

    <section class="demo-section">
      <h2>Buttons and badges</h2>
      <div class="demo-row">
        @button({ variant: 'primary' })
          Primary
        @end
        @button({ variant: 'outline', size: 'sm' })
          Outline small
        @end
        @badge({ variant: 'secondary' })
          New
        @end
      </div>
    </section>

    <section class="demo-section">
      <h2>Alert</h2>
      @alert({ variant: 'default', title: 'Heads up', description: 'You can add components to your app.' })
      @end
    </section>

    <section class="demo-section">
      <h2>Card</h2>
      @card()
        @slot('header')
          <h2>Card title</h2>
          <p>Card description</p>
        @end
        @slot('section')
          <p>Card content goes here.</p>
        @end
        @slot('footer')
          @button({ variant: 'outline' })
            Action
          @end
        @end
      @end
    </section>

    <section class="demo-section">
      <h2>Form controls</h2>
      @component('components/field', { label: 'Email', description: 'We will never share your email.' })
        @component('components/input', { type: 'email', name: 'email', placeholder: 'you@example.com' })
        @end
      @end
      <div class="demo-row">
        @checkbox({ name: 'terms', label: 'Accept terms' })
        @end
        @switch({ name: 'notifications', label: 'Enable notifications' })
        @end
      </div>
    </section>

    <section class="demo-section">
      <h2>Accordion</h2>
      @accordion()
        <details open>
          <summary>
            Is it accessible?
            @svg('lucide:chevron-down')
          </summary>
          <section>Yes. It uses native disclosure semantics.</section>
        </details>
        <details>
          <summary>
            Is it styled?
            @svg('lucide:chevron-down')
          </summary>
          <section>Yes. It comes with basecoat styles.</section>
        </details>
      @end
    </section>

    <section class="demo-section">
      <h2>Tabs</h2>
      @tabs({
        id: 'demo-tabs',
        tabsets: [
          { tab: 'Account', panel: '<p>Account settings</p>' },
          { tab: 'Password', panel: '<p>Change your password</p>' },
          { tab: 'Team', panel: '<p>Manage your team</p>' },
        ],
      })
      @end
    </section>

    <section class="demo-section">
      <h2>Dialog</h2>
      @dialog({
        id: 'demo-dialog',
        trigger: 'Open dialog',
        title: 'Edit profile',
        description: 'Make changes to your profile here.',
      })
        @slot('main')
          <p>Dialog body content.</p>
        @end
        @slot('footer')
          @button({ variant: 'outline' })
            Cancel
          @end
          @button()
            Save
          @end
        @end
      @end
    </section>

    <section class="demo-section">
      <h2>Dropdown menu</h2>
      @dropdownMenu({
        id: 'demo-dropdown',
        items: [
          { label: 'Profile', type: 'item' },
          { label: 'Settings', type: 'item' },
          { type: 'separator' },
          { label: 'Logout', type: 'item' },
        ],
      })
        @slot('trigger')
          Open menu
        @end
      @end
    </section>

    <section class="demo-section">
      <h2>Table</h2>
      @table()
        <thead>
          <tr><th>Name</th><th>Status</th></tr>
        </thead>
        <tbody>
          <tr><td>Ada Lovelace</td><td>Active</td></tr>
          <tr><td>Alan Turing</td><td>Active</td></tr>
        </tbody>
      @end
    </section>

    <section class="demo-section">
      <h2>Progress and skeleton</h2>
      <div class="demo-row">
        @progress({ value: 60, max: 100 })
        @end
        @skeleton()
          <div style="height: 2rem; width: 12rem;"></div>
        @end
      </div>
    </section>

    <section class="demo-section">
      <h2>Toast container</h2>
      @toast({
        toasts: [
          { category: 'success', title: 'Saved', description: 'Your changes have been saved.' },
        ],
      })
      @end
    </section>
  </div>
</body>
</html>
