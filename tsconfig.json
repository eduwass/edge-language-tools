{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "types": ["bun-types"]
  },
  "include": ["packages/*/src", "packages/*/tests"],
  "exclude": ["packages/codegen/tests/fixture-app"]
}
